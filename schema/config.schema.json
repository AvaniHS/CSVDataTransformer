{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://csv-data-transformer.local/schema/config.schema.json",
  "title": "CSV Data Transformer Config",
  "type": "object",
  "required": ["migration_id", "client_id", "version", "connections", "blueprints"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "migration_id": { "type": "string", "minLength": 1 },
    "client_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "connections": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/connection" }
    },
    "blueprints": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/blueprint" }
    }
  },
  "$defs": {
    "connection": {
      "type": "object",
      "required": ["type", "base_path", "target_path"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["LOCAL_FILE_DIRECTORY", "LOCAL_CSV_DIRECTORY"]
        },
        "base_path": { "type": "string", "minLength": 1 },
        "target_path": { "type": "string", "minLength": 1 },
        "file_options": { "$ref": "#/$defs/fileOptions" }
      }
    },
    "fileOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "format": { "type": "string", "default": "CSV" },
        "encoding": { "type": "string", "default": "utf-8" },
        "delimiter": { "type": "string", "default": "," },
        "quote_char": { "type": "string", "default": "\"" },
        "header_row": { "type": "boolean", "default": true },
        "max_file_size_mb": { "type": "integer", "minimum": 1, "default": 100 }
      }
    },
    "blueprint": {
      "type": "object",
      "required": ["sequence_order", "blueprint_id", "sources", "target", "mappings"],
      "additionalProperties": false,
      "properties": {
        "sequence_order": { "type": "integer", "minimum": 1 },
        "blueprint_id": { "type": "string", "minLength": 1 },
        "comment": { "type": "string" },
        "sources": { "$ref": "#/$defs/sources" },
        "target": { "$ref": "#/$defs/target" },
        "pre_filters": {
          "type": "array",
          "items": { "$ref": "#/$defs/filterItem" },
          "default": []
        },
        "derivations": {
          "type": "array",
          "items": { "$ref": "#/$defs/derivation" },
          "default": []
        },
        "post_filters": {
          "type": "array",
          "items": { "$ref": "#/$defs/filterItem" },
          "default": []
        },
        "mappings": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/mapping" }
        }
      }
    },
    "sources": {
      "type": "object",
      "required": ["root_table"],
      "additionalProperties": false,
      "properties": {
        "root_table": { "$ref": "#/$defs/rootTable" },
        "joins": {
          "type": "array",
          "items": { "$ref": "#/$defs/join" },
          "default": []
        }
      }
    },
    "rootTable": {
      "type": "object",
      "required": ["connection_ref", "file_name", "alias"],
      "additionalProperties": false,
      "properties": {
        "connection_ref": { "type": "string", "minLength": 1 },
        "file_name": { "type": "string", "minLength": 1 },
        "alias": { "type": "string", "minLength": 1 },
        "comment": { "type": "string" }
      }
    },
    "join": {
      "type": "object",
      "required": ["join_type", "connection_ref", "file_name", "alias", "conditions"],
      "additionalProperties": false,
      "properties": {
        "join_type": {
          "type": "string",
          "enum": ["LEFT", "INNER", "RIGHT", "OUTER"]
        },
        "connection_ref": { "type": "string", "minLength": 1 },
        "file_name": { "type": "string", "minLength": 1 },
        "alias": { "type": "string", "minLength": 1 },
        "conditions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/joinConditionItem" }
        },
        "comment": { "type": "string" }
      }
    },
    "target": {
      "type": "object",
      "required": ["connection_ref", "file_name"],
      "additionalProperties": false,
      "properties": {
        "connection_ref": { "type": "string", "minLength": 1 },
        "file_name": { "type": "string", "minLength": 1 },
        "comment": { "type": "string" }
      }
    },
    "mapping": {
      "type": "object",
      "required": ["target_column", "source_type", "source_value", "cast_to", "is_nullable"],
      "additionalProperties": false,
      "properties": {
        "target_column": { "type": "string", "minLength": 1 },
        "source_type": {
          "type": "string",
          "enum": ["DIRECT", "DERIVED", "EXPRESSION"]
        },
        "source_value": { "type": "string", "minLength": 1 },
        "cast_to": {
          "type": "string",
          "enum": ["str", "int64", "float64", "datetime64[ns]"]
        },
        "is_nullable": { "type": "boolean" },
        "default_value": {}
      }
    },
    "predicate": {
      "type": "object",
      "required": ["left", "operator"],
      "additionalProperties": false,
      "properties": {
        "left": { "type": "string", "minLength": 1 },
        "operator": { "type": "string", "minLength": 1 },
        "right": {},
        "right_type": {
          "type": "string",
          "enum": ["literal", "column"]
        }
      }
    },
    "conditionGroup": {
      "type": "object",
      "required": ["logic", "conditions"],
      "additionalProperties": false,
      "properties": {
        "logic": { "type": "string", "enum": ["AND", "OR"] },
        "conditions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/joinConditionItem" }
        }
      }
    },
    "expressionFilter": {
      "type": "object",
      "required": ["type", "value"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "expression" },
        "value": { "type": "string", "minLength": 1 }
      }
    },
    "joinConditionItem": {
      "oneOf": [
        { "$ref": "#/$defs/predicate" },
        { "$ref": "#/$defs/conditionGroup" }
      ]
    },
    "filterItem": {
      "oneOf": [
        { "$ref": "#/$defs/predicate" },
        { "$ref": "#/$defs/conditionGroup" },
        { "$ref": "#/$defs/expressionFilter" }
      ]
    },
    "derivation": {
      "oneOf": [
        { "$ref": "#/$defs/expressionDerivation" },
        { "$ref": "#/$defs/regexpReplaceDerivation" },
        { "$ref": "#/$defs/caseDerivation" }
      ]
    },
    "expressionDerivation": {
      "type": "object",
      "required": ["variable_name", "transform_type", "expression"],
      "additionalProperties": false,
      "properties": {
        "variable_name": { "type": "string", "minLength": 1 },
        "transform_type": { "const": "EXPRESSION" },
        "expression": { "type": "string", "minLength": 1 },
        "comment": { "type": "string" }
      }
    },
    "regexpReplaceDerivation": {
      "type": "object",
      "required": ["variable_name", "transform_type", "source", "pattern", "replacement"],
      "additionalProperties": false,
      "properties": {
        "variable_name": { "type": "string", "minLength": 1 },
        "transform_type": { "const": "REGEXP_REPLACE" },
        "source": { "type": "string", "minLength": 1 },
        "pattern": { "type": "string" },
        "replacement": { "type": "string" },
        "comment": { "type": "string" }
      }
    },
    "caseDerivation": {
      "type": "object",
      "required": ["variable_name", "transform_type", "branches"],
      "additionalProperties": false,
      "properties": {
        "variable_name": { "type": "string", "minLength": 1 },
        "transform_type": { "const": "CASE" },
        "branches": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/caseBranch" }
        },
        "else": {},
        "comment": { "type": "string" }
      }
    },
    "caseBranch": {
      "type": "object",
      "required": ["when", "then"],
      "additionalProperties": false,
      "properties": {
        "when": { "$ref": "#/$defs/joinConditionItem" },
        "then": {}
      }
    }
  }
}
